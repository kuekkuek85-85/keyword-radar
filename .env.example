# ─────────────────────────────────────────────────────────────
# 키워드 레이더 환경변수 예시
# 로컬: 이 파일을 .env 로 복사해 값을 채우세요.
# 배포: Vercel 프로젝트 Settings > Environment Variables 에 등록하세요.
# ─────────────────────────────────────────────────────────────

# ── Firebase (클라이언트, 웹앱) ──────────────────────────────
# Firebase 콘솔 > 프로젝트 설정 > 내 앱(웹) 의 SDK 구성 값.
# Vite 는 VITE_ 접두사가 붙은 변수만 클라이언트 번들에 노출합니다.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 웹앱 로그인 허용 이메일 (쉼표 구분 화이트리스트)
VITE_ALLOWED_EMAILS=you@example.com

# ── Firebase (서버, Admin SDK) ───────────────────────────────
# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성.
# 다운로드한 JSON 을 한 줄 문자열로 넣습니다 (개행은 \n 유지).
FIREBASE_SERVICE_ACCOUNT_KEY=
# 서버에서 사용할 프로젝트 ID (보통 위 project_id 와 동일)
FIREBASE_PROJECT_ID=your-project

# ── 텔레그램 봇 ──────────────────────────────────────────────
# @BotFather 로 봇 생성 후 발급되는 토큰.
TELEGRAM_BOT_TOKEN=
# 알림을 받을 채팅 ID (본인 계정 또는 채널).
TELEGRAM_CHAT_ID=
# 웹훅 검증용 시크릿 (임의의 긴 랜덤 문자열).
# setWebhook 시 secret_token 으로 등록하고, 수신 요청 헤더와 대조합니다.
TELEGRAM_WEBHOOK_SECRET=

# ── 크론 보호 ────────────────────────────────────────────────
# /api/scan 을 수동/외부 호출로부터 보호. Vercel Cron 은
# Authorization: Bearer <CRON_SECRET> 헤더를 자동으로 붙여줍니다.
CRON_SECRET=

# ── 웹 검색 API ──────────────────────────────────────────────
# 사용할 제공자: "serper" 또는 "tavily"
SEARCH_PROVIDER=serper
# Serper (https://serper.dev)
SERPER_API_KEY=
# Tavily (https://tavily.com)
TAVILY_API_KEY=

# ── YouTube Data API v3 ──────────────────────────────────────
# Google Cloud Console 에서 YouTube Data API v3 활성화 후 API 키 발급.
YOUTUBE_API_KEY=

# ── 스캔 동작 튜닝 ───────────────────────────────────────────
# 키워드당 1회 알림 상한 (알림 피로 방지).
MAX_NOTIFY_PER_KEYWORD=5
